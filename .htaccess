# ─── Directory Security ───────────────────────────────────────────────────────
# Disable directory listings
Options -Indexes

# ─── PHP Settings ─────────────────────────────────────────────────────────────
<IfModule mod_php.c>
    php_flag  display_errors        Off
    php_value error_reporting       22519
    php_value upload_max_filesize   20M
    php_value post_max_size         22M
    php_value max_execution_time    300
    php_value max_input_time        300
    php_value memory_limit          256M
</IfModule>

<IfModule mod_php8.c>
    php_flag  display_errors        Off
    php_value error_reporting       22519
    php_value upload_max_filesize   20M
    php_value post_max_size         22M
    php_value max_execution_time    300
    php_value max_input_time        300
    php_value memory_limit          256M
</IfModule>

# ─── Block direct access to sensitive folders ──────────────────────────────────
# Protect PHP includes / libraries
<FilesMatch "\.(inc\.php|inc)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block direct access to internal folders
RedirectMatch 403 ^/code/.*$
RedirectMatch 403 ^/connections/.*$
RedirectMatch 403 ^/php_lib/.*$
RedirectMatch 403 ^/logs/.*$
RedirectMatch 403 ^/smarty/.*$
RedirectMatch 403 ^/fatal/.*$

# ─── URL Rewriting ────────────────────────────────────────────────────────────
RewriteEngine On

# Redirige la raíz a /home (URL limpia)
RewriteRule ^$ /home [R=301,L]

# URLs limpias → scripts internos (invisible para el visitante)
RewriteRule ^home$       scripts/A_home.php [L]
RewriteRule ^about$      scripts/A_home.php [L]
RewriteRule ^music$      scripts/A_home.php [L]
RewriteRule ^shows$      scripts/A_home.php [L]
RewriteRule ^videos$     scripts/A_home.php [L]
RewriteRule ^photos$     scripts/A_home.php [L]
RewriteRule ^contact$    scripts/A_contact.php [L]

# Bloquea acceso directo a /scripts/ desde el browser
RewriteCond %{THE_REQUEST} /scripts/ [NC]
RewriteRule ^scripts/A_home\.php$ /home [R=301,L]
RewriteRule ^scripts/A_contact\.php$ /contact [R=301,L]

# Allow actual files and directories through
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
